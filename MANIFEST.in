include LICENSE
include README.md
include CHANGELOG.md
include pyproject.toml

# Cython sources + C/C++ headers for the package (so the sdist can be recompiled)
recursive-include cy_redis *.pyx *.pxd *.pyi *.hpp *.h py.typed
recursive-include cyredis_game *.py *.pyx *.pxd *.md *.sh

# Vendored hiredis — sources, headers, and Makefile only. libhiredis.a is
# deliberately NOT shipped: a static archive is platform-specific, and
# setup.py rebuilds it from these sources on every fresh sdist install.
recursive-include hiredis *.c *.h Makefile

# Lua scripts shipped at runtime
recursive-include lua_scripts *.lua *.md

# pgcache Redis module sources (server-side C module, scoped to src/)
recursive-include plugins *.py *.md
recursive-include plugins/pgcache/src *.c *.h
include plugins/pgcache/Makefile plugins/pgcache/build_module.sh

# Examples and docs
recursive-include examples *.py *.md
recursive-include docs *.md *.rst

global-exclude *.pyc
global-exclude *.pyo
global-exclude *.so
global-exclude *.o
global-exclude *.a
global-exclude __pycache__
global-exclude .DS_Store
global-exclude .git*
prune .github
prune build
prune dist
prune htmlcov
prune **/psqlodbc
